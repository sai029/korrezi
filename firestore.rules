rules_version = '2';

// 認証済みユーザーを前提とする（匿名認証でOK）。
// news_pool / personalized_feed への書き込みは Cloud Functions (Admin SDK) のみ。
// クライアントから直接書き込む手段は持たない。
service cloud.firestore {
  match /databases/{database}/documents {

    // 元記事プール: 認証済みなら読み取り可。書き込みは Admin SDK のみ（Cloud Functions）。
    match /news_pool/{newsId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 除外記事ログ: 採点ゲートで落とした記事の監査用。クライアントからは読み書き不可
    // （Admin SDK のみ書き込み／Firebase コンソールで確認する）。
    match /rejected_articles/{newsId} {
      allow read, write: if false;
    }

    // パーソナライズフィード: 本人のみ読み書き可（テレメトリの recordView のみ書き込む）。
    match /users/{userId}/personalized_feed/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 興味プロファイル: 本人のみ読み書き可（将来の閲覧履歴反映を見込んでクライアント書き込みも許可）。
    match /users/{userId}/interest_profile/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // その他のユーザーデータ（FCM トークン users/{uid}/fcm_tokens/{token} を含む）: 本人のみ。
    // 通知の送信側（Cloud Functions / Admin SDK）はこのルールに関係なく読み取れる。
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
